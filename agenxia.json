{
  "name": "Basic Agent",
  "description": "Simple API agent with basic endpoints for status and data processing",
  "type": "template",
  "icon": "🤖",
  "complexity": "beginner",
  "features": [
    "RESTful API endpoints",
    "Status monitoring",
    "Basic data processing",
    "Environment variables",
    "Simple configuration"
  ],
  "config": {
    "system_prompt": "You are {{AGENT_NAME}}. {{AGENT_DESCRIPTION}}",
    "model": "llama-3.3-70b",
    "temperature": 0.7,
    "max_tokens": 4096
  },
  "env_vars": [
    "AGENT_NAME",
    "AGENT_ID",
    "PLATFORM_URL",
    "PORT",
    "LLM_API_KEY",
    "LLM_API_URL"
  ],
  "metadata": {
    "author": "agenxia",
    "source_template": null,
    "type": "template"
  }
}
